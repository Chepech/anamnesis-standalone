{
  "name": "@anamnesis/app",
  "version": "0.1.0",
  "description": "Anamnesis tray app — Electron desktop interface",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chepech/anamnesis-standalone.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -skipLibCheck && node esbuild.renderer.mjs",
    "build:main": "tsc -skipLibCheck",
    "build:renderer": "node esbuild.renderer.mjs",
    "dev": "tsc -skipLibCheck --watch",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "start": "electron dist/main/index.js",
    "package": "electron-builder --dir",
    "package:linux": "electron-builder --linux --publish always",
    "package:mac": "electron-builder --mac --publish always",
    "package:win": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@anamnesis/core": "workspace:*",
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "umap-js": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.24.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "5.7.2"
  },
  "build": {
    "appId": "dev.anamnesis.app",
    "productName": "Anamnesis",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "files": ["dist/**/*", "renderer/**/*"],
    "extraResources": [
      { "from": "../core/dist/", "to": "core/", "filter": ["**/*"] },
      { "from": ".deploy-core/node_modules/", "to": "core/node_modules/", "filter": ["**/*"] },
      { "from": "../../assets/", "to": "assets/", "filter": ["**/*"] }
    ],
    "icon": "../../assets/AnamnesisLogo.png",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Hector Nevarez <chepech@gmail.com>"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "compression": "lzma"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}
